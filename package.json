{
  "name": "math",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run --filter mathend dev",
    "dev:desktop": "turbo run --filter desktop dev",
    "tauri:dev": "bun run --filter desktop tauri:dev",
    "tauri:build": "bun run --filter desktop tauri:build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "bun run --cwd ./test test",
    "test:watch": "bun run --cwd ./test test:watch",
    "test:coverage": "bun run --cwd ./test test:coverage",
    "verify": "bun run lint && bun run check-types && bun run test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.20"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
