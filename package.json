{
  "name": "math",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run --filter mathend dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "bun run lint && bun run check-types && bun run test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "prettier": "^3.7.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "turbo": "^2.8.20",
    "typescript": "5.9.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
