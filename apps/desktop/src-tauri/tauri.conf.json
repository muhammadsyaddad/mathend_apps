{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mathend Desktop",
  "version": "0.1.0",
  "identifier": "dev.mathend.desktop",
  "build": {
    "beforeDevCommand": "bun run --cwd ../.. --filter desktop dev",
    "beforeBuildCommand": "bun run --cwd ../.. --filter desktop build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mathend Desktop",
        "width": 1400,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
